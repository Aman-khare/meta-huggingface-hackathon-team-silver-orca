# Auto-detect text files and normalize line endings
* text=auto

# Enforce LF line endings for source code and config files
*.py text eol=lf
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.ipynb text eol=lf

# Binary assets (do not modify)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# Custom diff driver for Python files
*.py diff=python
